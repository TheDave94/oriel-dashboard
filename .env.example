# Credentials for the test layer only — Playwright e2e + e2e-browser specs
# read these. Plain `npm run build` and `npm run lint` do NOT need them.
#
# Copy this file to .env.local and fill in real values. .env.local is
# gitignored — never commit it. Conventions for credentialed work in this
# repo are documented in CLAUDE.md → "Credentials and HA API access" and
# based on /opt/autocoder/CREDENTIAL_CONVENTIONS_TEMPLATE.md.

# Home Assistant base URL (no trailing slash) — used as Playwright's
# base URL and by tests that hit the HA REST API directly.
HA_URL=

# Long-lived HA access token. HA 2026.5.x does not support fine-grained
# tokens — this is full admin scope. Same token value lives in
# ~/.hermes/.env and /opt/repos/homeassistant-config/.env.local;
# rotation touches all three locations.
HA_TOKEN=

# Dashboard URL path for browser tests (default in code: "oriel-dashboard"
# or "dashboard-oriel" depending on the spec). Not a credential — config.
HA_DASHBOARD_URL_PATH=
